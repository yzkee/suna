# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Kortix — Root Environment Configuration                                   ║
# ║                                                                             ║
# ║  1. Copy this file:  cp .env.example .env                                  ║
# ║  2. Fill in values below                                                    ║
# ║  3. Run:  ./scripts/setup-env.sh                                           ║
# ║                                                                             ║
# ║  The setup script distributes these values to each service's .env file.    ║
# ║                                                                             ║
# ║  Architecture:                                                              ║
# ║    Frontend ◀──▶ Kortix API ◀──▶ Sandbox                                   ║
# ║                      │                                                      ║
# ║                  PostgreSQL                                                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── General ─────────────────────────────────────────────────────────────────
# Deprecated — no longer affects auth or routing. Kept for reference.
# ENV_MODE=local

# ══════════════════════════════════════════════════════════════════════════════
# KORTIX API — Backend, router, auth, integrations
# ══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ────────────────────────────────────────────────────────────────
# Local: auto-populated from `supabase status` after running `supabase start`.
# Cloud: from your Supabase project settings → API → Project URL / Keys.
SUPABASE_URL=http://127.0.0.1:64321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Local: Supabase CLI runs postgres on port 64322 (auto from `supabase start`).
# Cloud: your Supabase DB connection string (Settings → Database → URI).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres

# ─── Scheduler (pg_cron) ────────────────────────────────────────────────────
# pg_cron is built into Supabase's postgres — no custom image needed.
# Auto-set in Docker Compose.
CRON_TICK_SECRET=local-dev-cron-secret
# NOTE: pg_cron runs inside Supabase's DB Docker container, so it needs
# host.docker.internal to reach the API on the host machine (not localhost).
CRON_API_URL=http://host.docker.internal:8008

# ─── Auth ────────────────────────────────────────────────────────────────────
# Shared secret for API key HMAC hashing
API_KEY_SECRET=

# ─── Sandbox Provisioning ───────────────────────────────────────────────────
# Comma-separated list of allowed sandbox providers.
# First entry is the default for new sandboxes.
# Options: daytona, local_docker
ALLOWED_SANDBOX_PROVIDERS=local_docker

# Daytona (cloud sandbox provider)
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=

# Local Docker (self-hosted sandbox provider)
SANDBOX_IMAGE=kortix/sandbox:latest
# DOCKER_HOST=unix:///var/run/docker.sock  # default — override for remote Docker
# SANDBOX_NETWORK=                         # custom Docker network (optional)

# ─── Sandbox Auth (optional) ────────────────────────────────────────────────
# Set both to the same value to protect sandbox access with a bearer token.
# VPS mode: auto-generated by get-kortix.sh. Local mode: opt-in.
# SANDBOX_AUTH_TOKEN=            # User → kortix-api proxy auth
# INTERNAL_SERVICE_KEY=          # kortix-api → sandbox service-to-service auth

# ─── Integrations (Pipedream Connect — 3,000+ third-party apps) ─────────────
# Enables OAuth integrations (Gmail, Slack, GitHub, Notion, etc.)
# Get credentials at: https://pipedream.com/connect
INTEGRATION_AUTH_PROVIDER=pipedream
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development

# ─── Router API Keys (cloud mode only) ──────────────────────────────────────
# In cloud mode, sandbox tool/LLM requests are routed through the Kortix API
# router proxy. The router injects these Kortix-owned keys into upstream
# requests so individual sandboxes don't need their own.
#
# NOT used in local mode — local sandboxes use their own keys directly
# (configured via the browser setup wizard or sandbox secret store).

# LLM Providers — router proxies LLM requests in cloud mode
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Tool Providers — router proxies tool requests in cloud mode
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
REPLICATE_API_TOKEN=
CONTEXT7_API_KEY=

# ─── Internal Deployment Controls ───────────────────────────────────────────
# INTERNAL_KORTIX_ENV: dev | staging | prod (default: dev)
# Controls: Stripe price IDs, analytics, log levels. Does NOT affect auth.
INTERNAL_KORTIX_ENV=dev

# Feature flags for Kortix Cloud internal services.
# Default: false — safe for self-hosted deployments.
KORTIX_ROUTER_INTERNAL_ENABLED=false
KORTIX_BILLING_INTERNAL_ENABLED=false

# ─── Billing — Stripe (cloud only) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Billing — RevenueCat (optional — mobile billing, cloud only) ───────────
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_SECRET_KEY=

# ─── Deployments — Freestyle (cloud only) ───────────────────────────────────
FREESTYLE_API_KEY=
FREESTYLE_API_URL=https://api.freestyle.sh

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND — Next.js dashboard
# ══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1
# Whether billing/payments UI is shown (Stripe, credit tracking, download restrictions).
# Self-hosted: false or omit. Kortix Cloud: true.
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
KORTIX_ADMIN_API_KEY=

# ─── Slack (frontend OAuth — optional) ──────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
