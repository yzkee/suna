# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Kortix — Root Environment Configuration                                   ║
# ║                                                                             ║
# ║  1. Copy this file:  cp .env.example .env                                  ║
# ║  2. Fill in values below                                                    ║
# ║  3. Run:  ./scripts/setup-env.sh                                           ║
# ║                                                                             ║
# ║  The setup script distributes these values to each service's .env file.    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Environment ─────────────────────────────────────────────────────────────
# local | cloud
ENV_MODE=local

# ─── Stripe Environment ─────────────────────────────────────────────────────
# staging | production — controls which Stripe price IDs to use (cloud only)
STRIPE_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose (local): auto-set to postgres:5432 via compose environment.
# Bare-metal dev: point to your own PostgreSQL or Supabase CLI (port 54322).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Scheduler (pg_cron) ────────────────────────────────────────────────────
# Enables pg_cron-based cron scheduling. Auto-set in Docker Compose.
# CRON_API_URL is the base URL pg_cron uses to call back to the API.
# CRON_TICK_SECRET is a shared secret for authenticating cron callbacks.
CRON_TICK_SECRET=local-dev-cron-secret
CRON_API_URL=http://localhost:8008

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Shared secret for API key HMAC hashing
API_KEY_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── RevenueCat (optional — mobile billing) ──────────────────────────────────
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_SECRET_KEY=

# ─── Sandbox Provisioning ───────────────────────────────────────────────────
# Provider: 'daytona' (cloud only), 'local_docker' (local only), or 'auto' (both)
SANDBOX_PROVIDER=auto

# Daytona (cloud sandbox provider)
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=

# Local Docker (self-hosted sandbox provider)
SANDBOX_IMAGE=kortix/sandbox:latest
# DOCKER_HOST=unix:///var/run/docker.sock  # default — override for remote Docker
# SANDBOX_NETWORK=                         # custom Docker network (optional)

# ─── Sandbox Auth (optional) ─────────────────────────────────────────────────
# Set both to the same value to protect sandbox access with a bearer token.
# VPS mode: auto-generated by get-kortix.sh. Local mode: opt-in.
# SANDBOX_AUTH_TOKEN=            # User → kortix-api proxy auth
# INTERNAL_SERVICE_KEY=          # kortix-api → sandbox service-to-service auth

# ─── LLM Providers (fill at least one) ──────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ─── Tool Providers (optional) ──────────────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
REPLICATE_API_TOKEN=
CONTEXT7_API_KEY=

# ─── Freestyle (Deployments) ───────────────────────────────────────────────
FREESTYLE_API_KEY=
FREESTYLE_API_URL=https://api.freestyle.sh

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1
NEXT_PUBLIC_ENV_MODE=local
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
KORTIX_ADMIN_API_KEY=

# ─── Integrations (OAuth Provider — Pipedream Connect) ────────────────────
INTEGRATION_AUTH_PROVIDER=pipedream
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
