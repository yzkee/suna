# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Kortix — Root Environment Configuration                                   ║
# ║                                                                             ║
# ║  1. Copy this file:  cp .env.example .env                                  ║
# ║  2. Fill in values below                                                    ║
# ║  3. Run:  ./scripts/setup-env.sh                                           ║
# ║                                                                             ║
# ║  The setup script distributes these values to each service's .env file.    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Environment ─────────────────────────────────────────────────────────────
# local | staging | production
ENV_MODE=local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Shared secret for API key HMAC hashing (must match between kortix-auth & kortix-router)
API_KEY_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── RevenueCat (optional — mobile billing) ──────────────────────────────────
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_SECRET_KEY=

# ─── Daytona (sandbox management) ───────────────────────────────────────────
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=

# ─── LLM Providers (fill at least one) ──────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ─── Tool Providers (optional) ──────────────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
REPLICATE_API_TOKEN=
CONTEXT7_API_KEY=

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1
NEXT_PUBLIC_PLATFORM_URL=http://localhost:8012
NEXT_PUBLIC_ENV_MODE=local
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
KORTIX_ADMIN_API_KEY=
NEXT_PUBLIC_OPENCODE_URL=http://localhost:3111