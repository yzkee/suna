      "updated": 1,
      "link": null,
      "locked": false,
      "text": "ZUSTAND STORES (apps/frontend/src/stores/)\n\n▸ tool-stream-store.ts (79L) — Tool streaming state\n▸ server-store.ts (137L) — OpenCode server URLs\n▸ context-usage-store.ts (22L) — Token usage tracking\n▸ message-queue-store.ts (99L) — Queued messages for batch operations\n▸ agent-selection-store.ts (170L) — Selected agent configuration\n▸ tab-store.ts (261L) — UI tab navigation state\n▸ kortix-computer-store.ts (191L) — Computer environment state\n▸ model-store.ts (33L) — LLM model selection\n\nREACT QUERY (hooks organized by domain: agents/, threads/, billing/, opencode/, files/...)",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 212,
      "containerId": "zustand-stores-box",
      "originalText": "ZUSTAND STORES (apps/frontend/src/stores/)\n\n▸ tool-stream-store.ts (79L) — Tool streaming state\n▸ server-store.ts (137L) — OpenCode server URLs\n▸ context-usage-store.ts (22L) — Token usage tracking\n▸ message-queue-store.ts (99L) — Queued messages for batch operations\n▸ agent-selection-store.ts (170L) — Selected agent configuration\n▸ tab-store.ts (261L) — UI tab navigation state\n▸ kortix-computer-store.ts (191L) — Computer environment state\n▸ model-store.ts (33L) — LLM model selection\n\nREACT QUERY (hooks organized by domain: agents/, threads/, billing/, opencode/, files/...)",
      "lineHeight": 1.25
