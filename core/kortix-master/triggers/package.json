{
  "name": "@kortix/triggers",
  "version": "1.0.0",
  "description": "Unified trigger system: cron schedules, webhooks, with prompt/command/http actions",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "test/",
    "README.md",
    "TESTING.md",
    "tsconfig.json",
    "tsconfig.build.json",
    "docker-compose.test.yml",
    "Dockerfile"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx test/e2e.test.ts",
    "test:e2e": "tsx test/e2e.test.ts",
    "docker:e2e": "docker compose -f docker-compose.test.yml run --rm e2e-tests",
    "docker:typecheck": "docker compose -f docker-compose.test.yml run --rm typecheck"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.21",
    "croner": "^8.1.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
