#!/bin/sh
# apk-persist — wrapper around `apk add` that records packages to a manifest
# so they are automatically re-installed on container restart/update.
#
# Usage:  apk-persist <package> [package2] ...
#         apk-persist --list          Show saved packages
#         apk-persist --remove <pkg>  Remove from manifest (doesn't uninstall)
#
# Manifest: /workspace/.kortix/packages/apk-packages.txt
# One package per line. Restored at boot by 99-restore-packages init script.

set -e

MANIFEST="/workspace/.kortix/packages/apk-packages.txt"
mkdir -p "$(dirname "$MANIFEST")"
touch "$MANIFEST"

# ── Commands ─────────────────────────────────────────────────────────────────

if [ "$1" = "--list" ]; then
  if [ -s "$MANIFEST" ]; then
    echo "Persistent apk packages:"
    cat "$MANIFEST"
  else
    echo "No persistent apk packages saved."
  fi
  exit 0
fi

if [ "$1" = "--remove" ]; then
  shift
  for pkg in "$@"; do
    sed -i "/^${pkg}$/d" "$MANIFEST"
    echo "[apk-persist] Removed '$pkg' from manifest"
  done
  exit 0
fi

if [ $# -eq 0 ]; then
  echo "Usage: apk-persist <package> [package2] ..."
  echo "       apk-persist --list"
  echo "       apk-persist --remove <package>"
  exit 1
fi

# ── Install + record ─────────────────────────────────────────────────────────

echo "[apk-persist] Installing: $*"
apk add --no-cache "$@"

for pkg in "$@"; do
  if ! grep -qx "$pkg" "$MANIFEST" 2>/dev/null; then
    echo "$pkg" >> "$MANIFEST"
    echo "[apk-persist] Saved '$pkg' to manifest (will survive restarts)"
  fi
done

echo "[apk-persist] Done. ${#} package(s) installed and recorded."
