#!/usr/bin/with-contenv bash
# opencode-channels — Chat SDK Slack/Telegram bot on port 3456
# Starts immediately; Slack adapter activates only when credentials are present.
# After OAuth, kortix-api pushes credentials and restarts this service.

echo "[opencode-channels] Starting on port 3456"

# Kill any stale process holding the port (e.g. after unclean shutdown)
fuser -k 3456/tcp 2>/dev/null || true

# Run from kortix-master so bun resolves node_modules from the consolidated package.
# /opt/opencode-channels is a symlink to /opt/kortix-master/channels
cd /opt/kortix-master

if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc \
    env HOME=/workspace \
        OPENCODE_URL=http://localhost:4096 \
        PORT=3456 \
        PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin" \
        KORTIX_API_URL="${KORTIX_API_URL:-http://localhost:8008}" \
        KORTIX_TOKEN="${KORTIX_TOKEN:-}" \
        CHANNEL_CONFIG_ID="${CHANNEL_CONFIG_ID:-}" \
    /opt/bun/bin/bun run channels/src/index.ts
fi

exec env HOME=/workspace \
    OPENCODE_URL=http://localhost:4096 \
    PORT=3456 \
    PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin" \
    KORTIX_API_URL="${KORTIX_API_URL:-http://localhost:8008}" \
    KORTIX_TOKEN="${KORTIX_TOKEN:-}" \
    CHANNEL_CONFIG_ID="${CHANNEL_CONFIG_ID:-}" \
  /opt/bun/bin/bun run channels/src/index.ts
