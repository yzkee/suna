#!/usr/bin/with-contenv bash
# SSH Daemon — allows VS Code Remote SSH and direct SSH access into the sandbox.
# Host keys and authorized_keys are set up by the 95-setup-sshd init script.


echo "[sshd] Starting SSH daemon on port 22"

# Ensure host keys exist (init script should have created them)
if [ ! -f /etc/ssh/ssh_host_ed25519_key ]; then
  echo "[sshd] Generating host keys (first run)..."
  ssh-keygen -A
fi

# Run sshd in foreground mode (-D) so s6 can supervise it.
# -e logs to stderr (captured by s6).
exec /usr/sbin/sshd -D -e
