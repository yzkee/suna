#!/bin/bash
# Only clean up if daemon is actually dead — don't nuke a running daemon
SOCKET_DIR="${AGENT_BROWSER_SOCKET_DIR:-/dev/shm/agent-browser}"
PID=$(pgrep -n -f "node.*dist/daemon.js" 2>/dev/null)
if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
  # Daemon still running — service is restarting but daemon is fine
  # Don't kill it, let the new run script detect and adopt it
  :
else
  rm -f "$SOCKET_DIR"/*.sock "$SOCKET_DIR"/*.pid "$SOCKET_DIR"/*.stream "$SOCKET_DIR"/*.port 2>/dev/null || true
fi
sleep 1
