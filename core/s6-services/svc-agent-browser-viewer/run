#!/usr/bin/with-contenv bash
# Agent Browser Viewer — HTTP server on port 9224.
# ONLY manages the viewer. The daemon is managed by svc-agent-browser-session.

echo "[agent-browser-viewer] Starting on port 9224"

SOCKET_DIR="${AGENT_BROWSER_SOCKET_DIR:-/tmp/agent-browser}"
mkdir -p "$SOCKET_DIR"
if [ "$(id -u)" -eq 0 ]; then
  chown abc:users "$SOCKET_DIR" 2>/dev/null || true
fi

if [ "$(id -u)" -eq 0 ]; then
  exec env \
    HOME=/workspace \
    AGENT_BROWSER_SOCKET_DIR="$SOCKET_DIR" \
    AGENT_BROWSER_STREAM_PORT=9223 \
    s6-setuidgid abc bun run /ephemeral/services/agent-browser-viewer.js
fi

exec env \
  HOME=/workspace \
  AGENT_BROWSER_SOCKET_DIR="$SOCKET_DIR" \
  AGENT_BROWSER_STREAM_PORT=9223 \
  bun run /ephemeral/services/agent-browser-viewer.js
