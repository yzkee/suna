#!/usr/bin/with-contenv bash
# OpenCode Web UI on port 3111

PORT=3111

export HOME=/workspace
export XDG_DATA_HOME=/workspace/.local/share
export OPENCODE_CONFIG_DIR=/opt/kortix-master/opencode
export PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

[ -z "$ANTHROPIC_BASE_URL" ] && unset ANTHROPIC_BASE_URL
[ -z "$OPENAI_BASE_URL" ] && unset OPENAI_BASE_URL

# If the port is already in use (previous instance still alive), wait instead of crash-looping.
if netstat -tln 2>/dev/null | grep -q ":${PORT} "; then
  echo "[opencode-web] Port ${PORT} already in use — waiting for it to free up"
  while netstat -tln 2>/dev/null | grep -q ":${PORT} "; do
    sleep 5
  done
fi

cd /workspace

if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc /usr/local/bin/opencode web --port ${PORT} --hostname 0.0.0.0
fi

exec /usr/local/bin/opencode web --port ${PORT} --hostname 0.0.0.0
