#!/usr/bin/with-contenv bash
# OpenCode API server on port 4096 (proxied by kortix-master)
# with-contenv loads all s6 env vars (API keys, KORTIX_TOKEN, etc.) automatically.

# If the core supervisor owns this service, yield — it will manage opencode directly.
# Sleep keeps s6 happy (non-zero exit would trigger restart; sleep holds the slot).
if [ -f /opt/kortix/core/service-spec.json ]; then
  exec sleep infinity
fi

PORT=4096

export HOME=/workspace
export XDG_DATA_HOME=/workspace/.local/share
export OPENCODE_CONFIG_DIR=/opt/kortix-master/opencode
export OPENCODE_FILE_ROOT=/
export BUN_PTY_LIB=/opt/bun-pty-musl/librust_pty.so
export PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# ── PTY pre-flight diagnostics ──────────────────────────────────────────────
# Log PTY readiness so spawn failures are diagnosable from service logs.
echo "[opencode-serve] PTY check: bun=$(bun --version 2>/dev/null || echo 'NOT FOUND')"
echo "[opencode-serve] PTY check: BUN_PTY_LIB=${BUN_PTY_LIB:-unset}"
[ -f "$BUN_PTY_LIB" ] && echo "[opencode-serve] PTY check: .so exists ($(stat -c%s "$BUN_PTY_LIB" 2>/dev/null || stat -f%z "$BUN_PTY_LIB" 2>/dev/null) bytes)" \
                       || echo "[opencode-serve] PTY check: WARNING — BUN_PTY_LIB not found at $BUN_PTY_LIB"
[ -d /opt/kortix-master/node_modules/bun-pty ] && echo "[opencode-serve] PTY check: bun-pty module present" \
                                                || echo "[opencode-serve] PTY check: WARNING — bun-pty not in node_modules"

# Drop empty *_BASE_URL vars — empty string causes @ai-sdk to fetch("") → ERR_INVALID_URL
[ -z "$ANTHROPIC_BASE_URL" ] && unset ANTHROPIC_BASE_URL
[ -z "$OPENAI_BASE_URL" ] && unset OPENAI_BASE_URL

# If another instance is already serving on this port, just hold the slot.
# This prevents the "DB still locked" crash-loop where s6 keeps restarting
# a second instance that can't acquire the SQLite lock.
if netstat -tln 2>/dev/null | grep -q ":${PORT} "; then
  echo "[opencode-serve] Port ${PORT} already in use — holding slot"
  exec sleep infinity
fi

# Also check for stale SQLite WAL/SHM files that prevent startup
for f in /workspace/.local/share/opencode/storage/*.db-wal \
         /workspace/.local/share/opencode/storage/*.db-shm; do
  [ -f "$f" ] && rm -f "$f" 2>/dev/null && echo "[opencode-serve] Cleaned stale lock: $f"
done

cd /workspace

if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc /usr/local/bin/opencode serve --port ${PORT} --hostname 0.0.0.0
fi

exec /usr/local/bin/opencode serve --port ${PORT} --hostname 0.0.0.0
