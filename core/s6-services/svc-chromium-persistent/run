#!/usr/bin/with-contenv bash
# Persistent Chromium — always-on browser on DISPLAY=:1 with CDP on port 9222.
# agent-browser connects to this single instance via --cdp 9222.
# Profile in /workspace/.browser-profile survives container restarts.

source /ephemeral/services/service-manager-gate.sh
service_manager_require_enabled "chromium-persistent" "chromium-persistent"

echo "[chromium-persistent] Starting"

PROFILE_DIR="/workspace/.browser-profile"
mkdir -p "$PROFILE_DIR"
if [ "$(id -u)" -eq 0 ]; then
  chown -R abc:users "$PROFILE_DIR" 2>/dev/null || true
fi

# Remove stale singleton lock from unclean shutdown
rm -f "$PROFILE_DIR/SingletonLock" "$PROFILE_DIR/SingletonSocket" "$PROFILE_DIR/SingletonCookie" 2>/dev/null || true

# Wait for X display :1 socket (no xdpyinfo needed)
for i in $(seq 1 60); do
  if [ -S /tmp/.X11-unix/X1 ]; then
    echo "[chromium-persistent] X display :1 ready"
    break
  fi
  [ "$i" = "60" ] && echo "[chromium-persistent] WARNING: X1 socket not found after 60s"
  sleep 1
done

if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc env \
    DISPLAY=:1 \
    HOME=/workspace \
    /usr/bin/chromium-browser \
      --no-sandbox \
      --disable-gpu \
      --disable-dev-shm-usage \
      --remote-debugging-port=9222 \
      --remote-debugging-address=127.0.0.1 \
      --user-data-dir="$PROFILE_DIR" \
      --no-first-run \
      --no-default-browser-check \
      --disable-infobars \
      --disable-blink-features=AutomationControlled \
      --disable-features=VizDisplayCompositor \
      --start-maximized \
      about:blank
fi

exec env \
  DISPLAY=:1 \
  HOME=/workspace \
  /usr/bin/chromium-browser \
    --no-sandbox \
    --disable-gpu \
    --disable-dev-shm-usage \
    --remote-debugging-port=9222 \
    --remote-debugging-address=127.0.0.1 \
    --user-data-dir="$PROFILE_DIR" \
    --no-first-run \
    --no-default-browser-check \
    --disable-infobars \
    --disable-blink-features=AutomationControlled \
    --disable-features=VizDisplayCompositor \
    --start-maximized \
    about:blank
