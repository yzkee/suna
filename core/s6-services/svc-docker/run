#!/usr/bin/with-contenv bash
# Docker-in-Docker service — starts dockerd in privileged containers.
#
# Overrides the base image's svc-docker/run which calls dockerd-entrypoint.sh → dind.
# The stock dind script has TWO problems:
#   1. `mount -t tmpfs none /tmp` — wipes X11 sockets, breaks the desktop
#   2. cgroup v2 subtree_control loop — uses `sed` in a tight infinite retry loop
#      that spams "sed: write error" when the write races with new processes
#
# We handle cgroup setup ourselves (one-shot, no infinite loop) and skip the /tmp wipe.

source /ephemeral/services/service-manager-gate.sh
service_manager_require_enabled "docker" "docker"

# Only start if privileged AND explicitly requested
if [ ! -e /dev/cpu_dma_latency ]; then
  sleep infinity
fi

if [ "${START_DOCKER}" != "true" ]; then
  sleep infinity
fi

export container=docker

# Mount securityfs for AppArmor (same as dind, harmless if already mounted)
if [ -d /sys/kernel/security ] && ! mountpoint -q /sys/kernel/security; then
  mount -t securityfs none /sys/kernel/security 2>/dev/null || true
fi

# cgroup v2: enable nesting (one-shot, NOT an infinite retry loop)
if [ -f /sys/fs/cgroup/cgroup.controllers ]; then
  mkdir -p /sys/fs/cgroup/init
  # Move existing processes to /init — try a few times, then move on
  for _attempt in 1 2 3 4 5; do
    xargs -rn1 < /sys/fs/cgroup/cgroup.procs > /sys/fs/cgroup/init/cgroup.procs 2>/dev/null || true
    # Enable subtree controllers
    if sed -e 's/ / +/g' -e 's/^/+/' < /sys/fs/cgroup/cgroup.controllers \
        > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null; then
      break
    fi
    sleep 0.5
  done
fi

# Shared mount propagation (same as dind)
mount --make-rshared / 2>/dev/null || true

# Start dockerd directly — no dind wrapper, no /tmp wipe
exec dockerd --host=unix:///var/run/docker.sock -l error
