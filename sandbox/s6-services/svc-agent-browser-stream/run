#!/usr/bin/with-contenv bash
# Agent Browser Stream — connects to the persistent Chromium via CDP
# and starts the JPEG screencast stream on port 9223.
#
# By using --cdp 9222 (instead of launching its own Chrome), agent-browser
# attaches to the existing persistent Chromium instance. The user and the
# agent see and control the SAME browser.
#
# Named session "kortix" is the primary session shown in the frontend browser tab.

echo "[agent-browser-stream] Starting agent-browser stream (CDP connect to port 9222)"

SOCKET_DIR="/tmp/agent-browser"
mkdir -p "$SOCKET_DIR" /workspace
if [ "$(id -u)" -eq 0 ]; then
  chown -R abc:users "$SOCKET_DIR" 2>/dev/null || true
fi

# Wait for Chromium CDP to be ready
for i in $(seq 1 30); do
  if curl -sf http://127.0.0.1:9222/json/version >/dev/null 2>&1; then
    echo "[agent-browser-stream] Chromium CDP ready on port 9222"
    break
  fi
  echo "[agent-browser-stream] Waiting for Chromium CDP ($i/30)..."
  sleep 1
done

if ! curl -sf http://127.0.0.1:9222/json/version >/dev/null 2>&1; then
  echo "[agent-browser-stream] WARNING: Chromium CDP not ready after 30s, proceeding anyway"
fi

# Launch agent-browser in --headed mode connecting to the persistent Chrome via CDP.
# --cdp 9222           → connect to existing Chromium, don't spawn new one
# --session kortix     → name this session "kortix" (matches ?session=kortix in viewer)
# --stream-port 9223   → stream JPEG frames on this port
# open about:blank     → open initial page (CDP session needs a page to attach to)
if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc env \
    HOME=/workspace \
    DISPLAY=:1 \
    AGENT_BROWSER_CDP=9222 \
    AGENT_BROWSER_SOCKET_DIR="$SOCKET_DIR" \
    AGENT_BROWSER_STREAM_PORT=9223 \
    AGENT_BROWSER_HEADED=1 \
    AGENT_BROWSER_PROFILE=/workspace/.browser-profile \
    agent-browser --cdp 9222 --session kortix open about:blank
fi

exec env \
  HOME=/workspace \
  DISPLAY=:1 \
  AGENT_BROWSER_CDP=9222 \
  AGENT_BROWSER_SOCKET_DIR="$SOCKET_DIR" \
  AGENT_BROWSER_STREAM_PORT=9223 \
  AGENT_BROWSER_HEADED=1 \
  AGENT_BROWSER_PROFILE=/workspace/.browser-profile \
  agent-browser --cdp 9222 --session kortix open about:blank
