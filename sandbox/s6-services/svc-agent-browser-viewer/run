#!/usr/bin/with-contenv bash
# Agent Browser Viewer — serves browser viewer UI on port 9224
# Also provides SSE /stream and POST /input endpoints so the viewer
# can work behind an HTTP-only reverse proxy (no direct WS access).

echo "[agent-browser-viewer] Starting viewer on port 9224"

exec s6-setuidgid abc \
  bun -e '
    const fs = require("fs");
    const path = require("path");

    const html = fs.readFileSync("/opt/agent-browser-viewer/index.html");
    const socketDir = process.env.AGENT_BROWSER_SOCKET_DIR || "/workspace/.agent-browser";

    function getSessions() {
      try {
        const files = fs.readdirSync(socketDir);
        const sessions = [];
        for (const f of files) {
          if (f.endsWith(".stream")) {
            const name = f.replace(".stream", "");
            const port = parseInt(fs.readFileSync(path.join(socketDir, f), "utf8").trim(), 10);
            const hasSock = files.includes(name + ".sock");
            if (port > 0 && hasSock) {
              sessions.push({ name, port });
            }
          }
        }
        return sessions;
      } catch(e) { return []; }
    }

    // Track active SSE-to-WS bridges per port
    // Key: port number, Value: { ws, clients: Set<controller>, connecting }
    const bridges = new Map();

    function getOrCreateBridge(port) {
      if (bridges.has(port)) return bridges.get(port);

      const bridge = { ws: null, clients: new Set(), connecting: true };
      bridges.set(port, bridge);

      try {
        const ws = new WebSocket("ws://127.0.0.1:" + port);

        ws.addEventListener("open", () => {
          bridge.ws = ws;
          bridge.connecting = false;
        });

        ws.addEventListener("message", (event) => {
          const msg = typeof event.data === "string" ? event.data : event.data.toString();
          for (const client of bridge.clients) {
            try { client.enqueue("data: " + msg + "\n\n"); } catch {}
          }
        });

        ws.addEventListener("close", () => {
          bridge.ws = null;
          bridge.connecting = false;
          for (const client of bridge.clients) {
            try {
              client.enqueue("event: close\ndata: {}\n\n");
              client.close();
            } catch {}
          }
          bridge.clients.clear();
          bridges.delete(port);
        });

        ws.addEventListener("error", () => {
          bridge.ws = null;
          bridge.connecting = false;
          bridges.delete(port);
        });
      } catch (e) {
        bridge.connecting = false;
        bridges.delete(port);
      }

      return bridge;
    }

    Bun.serve({
      port: 9224,
      hostname: "0.0.0.0",
      fetch(req) {
        const url = new URL(req.url);
        const pathname = url.pathname;

        if (pathname === "/sessions") {
          return new Response(JSON.stringify(getSessions()), {
            headers: { "Content-Type": "application/json", "Cache-Control": "no-cache" },
          });
        }

        if (pathname === "/stream") {
          const port = parseInt(url.searchParams.get("port"), 10);
          if (!port || port < 1 || port > 65535) {
            return new Response("Bad port", { status: 400 });
          }

          const bridge = getOrCreateBridge(port);

          const stream = new ReadableStream({
            start(controller) {
              const encoder = { enqueue: (s) => controller.enqueue(new TextEncoder().encode(s)), close: () => controller.close() };
              bridge.clients.add(encoder);
              controller.enqueue(new TextEncoder().encode(":ok\n\n"));
            },
            cancel() {
              // Client disconnected — cleanup handled by GC since Set holds weak-ish refs
            },
          });

          return new Response(stream, {
            headers: {
              "Content-Type": "text/event-stream",
              "Cache-Control": "no-cache",
              "Connection": "keep-alive",
              "X-Accel-Buffering": "no",
            },
          });
        }

        if (pathname === "/input" && req.method === "POST") {
          const port = parseInt(url.searchParams.get("port"), 10);
          if (!port || port < 1 || port > 65535) {
            return new Response("Bad port", { status: 400 });
          }

          return req.text().then((body) => {
            const bridge = bridges.get(port);
            if (bridge && bridge.ws && bridge.ws.readyState === 1) {
              bridge.ws.send(body);
              return new Response("ok");
            }
            return new Response("No WS connection to port " + port, { status: 503 });
          });
        }

        // Default: serve the viewer HTML
        return new Response(html, {
          headers: { "Content-Type": "text/html", "Cache-Control": "no-cache" },
        });
      },
    });

    console.log("[agent-browser-viewer] Ready at http://0.0.0.0:9224");
  '
