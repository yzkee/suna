#!/bin/bash
# Kill any stale bun process holding port 3210 before restart
pkill -f "presentation-viewer.js" 2>/dev/null || true
port_hex=$(printf '%04X' 3210)
for pid_dir in /proc/[0-9]*/; do
  pid="${pid_dir//[^0-9]/}"
  [ -z "$pid" ] && continue
  for tcp_file in /proc/"$pid"/net/tcp /proc/"$pid"/net/tcp6; do
    grep -q " ${port_hex}:" "$tcp_file" 2>/dev/null && kill -9 "$pid" 2>/dev/null && break
  done
done
sleep 1
