#!/usr/bin/with-contenv bash
# Agent Browser Session — monitor-only service.
#
# Does NOT start its own daemon. Instead:
# 1. Patches stream-server.js (screencast watchdog)
# 2. Waits for the agent to start a daemon (via agent-browser CLI)
# 3. Ensures the .stream file exists so the viewer can discover it
# 4. Monitors the daemon — restarts the service if it dies
#
# The agent's daemon is the primary one. It launches its own Playwright
# browser and serves the stream on port 9223.

echo "[agent-browser-session] Starting (monitor mode)"

SOCKET_DIR="${AGENT_BROWSER_SOCKET_DIR:-/dev/shm/agent-browser}"
STREAM_PORT="${AGENT_BROWSER_STREAM_PORT:-9223}"
mkdir -p "$SOCKET_DIR"
if [ "$(id -u)" -eq 0 ]; then
  chown abc:users "$SOCKET_DIR" 2>/dev/null || true
fi

# ── Patch stream-server.js if not already patched ────────────────────────
# Fixes screencast dying silently on page/tab switch.
STREAM_SERVER="/usr/local/lib/node_modules/agent-browser/dist/stream-server.js"
if [ -f "$STREAM_SERVER" ] && ! grep -q '_lastFrameAt' "$STREAM_SERVER" 2>/dev/null; then
  echo "[agent-browser-session] Patching stream-server.js (screencast watchdog)"
  node -e "
    const fs = require('fs');
    let c = fs.readFileSync('$STREAM_SERVER', 'utf8');
    c = c.replace('broadcastFrame(frame) {', 'broadcastFrame(frame) { this._lastFrameAt = Date.now();');
    c = c.replace('if (this.clients.size === 1 && !this.isScreencasting)', 'if (!this.isScreencasting)');
    c = c.replace(
      '                    resolve();\n                });',
      [
        '                    resolve();',
        '                    this._lastFrameAt = 0;',
        '                    setInterval(() => {',
        '                        if (this.clients.size === 0) return;',
        '                        if (!this.isScreencasting) {',
        '                            this.startScreencast().then(() => {',
        '                                try { this.browser.getPage().evaluate(\"window.scrollBy(0,0)\").catch(()=>{}); } catch {}',
        '                            }).catch(() => {});',
        '                            return;',
        '                        }',
        '                        const staleMs = this._lastFrameAt ? Date.now() - this._lastFrameAt : 0;',
        '                        const bActive = typeof this.browser.isScreencasting === \"function\" ? this.browser.isScreencasting() : true;',
        '                        if (!bActive || (this._lastFrameAt > 0 && staleMs > 4000)) {',
        '                            this.isScreencasting = false; this._lastFrameAt = 0;',
        '                            this.startScreencast().then(() => {',
        '                                try { this.browser.getPage().evaluate(\"window.scrollBy(0,0)\").catch(()=>{}); } catch {}',
        '                            }).catch(() => {});',
        '                        }',
        '                    }, 2000);',
        '                });',
      ].join('\n')
    );
    // 4. EADDRINUSE: don't crash if another daemon already has the stream port.
    //    Just skip the stream server and let the existing one handle streaming.
    c = c.replace(
      \"this.wss.on('error', (error) => {\\n                    console.error('[StreamServer] WebSocket error:', error);\\n                    reject(error);\\n                });\",
      \"this.wss.on('error', (error) => {\\n                    if (error.code === 'EADDRINUSE') {\\n                        console.log('[StreamServer] Port ' + this.port + ' in use, reusing existing stream server');\\n                        this.wss = null;\\n                        resolve();\\n                        return;\\n                    }\\n                    console.error('[StreamServer] WebSocket error:', error);\\n                    reject(error);\\n                });\"
    );
    fs.writeFileSync('$STREAM_SERVER', c);
    console.log('[patch] stream-server.js patched');
  " 2>&1 || echo "[agent-browser-session] WARNING: patch failed"
fi

# ── Monitor loop ─────────────────────────────────────────────────────────
# Wait for a daemon to appear, then keep .stream file alive and monitor.
echo "[agent-browser-session] Waiting for agent daemon..."

while true; do
  # Look for a running daemon
  DAEMON_PID=$(pgrep -n -f "node.*dist/daemon.js" 2>/dev/null)

  if [ -n "$DAEMON_PID" ] && kill -0 "$DAEMON_PID" 2>/dev/null; then
    # Daemon is running — ensure discovery files exist
    echo "$DAEMON_PID" > "$SOCKET_DIR/kortix.pid" 2>/dev/null || true

    # Check if stream port is listening
    if node -e "const s=require('net').createConnection({port:$STREAM_PORT,host:'127.0.0.1'});s.on('connect',()=>{s.end();process.exit(0)});s.on('error',()=>process.exit(1))" 2>/dev/null; then
      # Stream server is up — write .stream file if missing
      if [ ! -f "$SOCKET_DIR/kortix.stream" ]; then
        echo "$STREAM_PORT" > "$SOCKET_DIR/kortix.stream" 2>/dev/null || true
        echo "[agent-browser-session] Registered stream port $STREAM_PORT for daemon $DAEMON_PID"
      fi
    fi
  fi

  sleep 5
done
