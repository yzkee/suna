{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": ["opencode-pty", "./plugin/worktree.ts", "./plugin/kortix-sys", "./plugin/kortix-tunnel/index.ts"],
  "skills": {
    "paths": ["./plugin/kortix-sys/skills"]
  },
  "autoupdate": true,
  "model": "kortix/anthropic/claude-sonnet-4.6",
  "default_agent": "kortix",
  "agent": {
    // Disable all built-in agents -- Kortix provides its own
    // "build": { "disable": true },
    // "plan": { "disable": true },
    // "explore": { "disable": true },
    // "general": { "disable": true }
    // compaction, title, summary are hidden infra agents -- leave them
  },
  "provider": {
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kortix",
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}",
        "headers": { "X-Session-ID": "{env:SANDBOX_ID}" }
      },
      "models": {
        "anthropic/claude-opus-4.6": {
          "name": "Claude Opus 4.6",
          "cost": { "input": 5, "output": 25, "cache_read": 0.50, "cache_write": 6.25 },
          "limit": { "context": 200000, "output": 16384 }
        },
        "openai/gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "cost": { "input": 1.75, "output": 14 },
          "limit": { "context": 400000, "output": 16384 }
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "cost": { "input": 3, "output": 15, "cache_read": 0.30, "cache_write": 3.75 },
          "limit": { "context": 200000, "output": 16384 }
        },
        "anthropic/claude-haiku-4.5": {
          "name": "Claude Haiku 4.5",
          "cost": { "input": 1, "output": 5, "cache_read": 0.10, "cache_write": 1.25 },
          "limit": { "context": 200000, "output": 8192 }
        },
        "minimax/minimax-m2.5": {
          "name": "MiniMax M2.5",
          "cost": { "input": 0.295, "output": 1.20 },
          "limit": { "context": 196608, "output": 8192 }
        },
        "z-ai/glm-5": {
          "name": "GLM-5",
          "cost": { "input": 0.95, "output": 2.55 },
          "limit": { "context": 204800, "output": 8192 }
        },
        "moonshotai/kimi-k2.5": {
          "name": "Kimi K2.5",
          "cost": { "input": 0.45, "output": 2.20 },
          "limit": { "context": 262144, "output": 8192 }
        },
        "x-ai/grok-4.1-fast": {
          "name": "Grok 4.1 Fast",
          "cost": { "input": 0.20, "output": 0.50 },
          "limit": { "context": 200000, "output": 16384 }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
