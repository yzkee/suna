{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": ["opencode-pty", "./plugin/worktree.ts", "./plugin/kortix-sys/src/index.ts", "./plugin/kortix-tunnel/index.ts"],
  "skills": {
    "paths": ["./plugin/kortix-sys/skills"]
  },
  "autoupdate": true,
  "default_agent": "kortix",
  "agent": {
    // Disable all built-in agents -- Kortix provides its own
    // "build": { "disable": true },
    // "plan": { "disable": true },
    // "explore": { "disable": true },
    // "general": { "disable": true }
    // compaction, title, summary are hidden infra agents -- leave them
  },
  "provider": {
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kortix",
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}"
      },
      "models": {
        "kortix/basic": {
          "name": "Kortix Basic",
          "cost": {
            "input": 3,
            "output": 15,
            "cache_read": 0.30,
            "cache_write": 3.75
          },
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "kortix/power": {
          "name": "Kortix Power",
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.50,
            "cache_write": 6.25
          },
          "limit": {
            "context": 200000,
            "output": 8192
          }
        }
      }
    },
    // ── LLM provider overrides for Kortix Cloud billing ──────────────
    //
    // In cloud mode, LLM traffic is routed through the Kortix proxy for
    // usage metering. X-Kortix-Token identifies the account for billing
    // at the platform fee rate (0.1×) when using user-owned keys.
    //
    // Base URL routing:
    //   Anthropic & OpenAI: routed via ANTHROPIC_BASE_URL / OPENAI_BASE_URL
    //     env vars (set by kortix-env-setup.sh, read by the SDK natively).
    //   XAI, Google, Groq: no SDK env var exists, so baseURL is set here
    //     using {env:KORTIX_API_URL}/provider. In local mode KORTIX_API_URL
    //     is empty and the SDK falls back to its hardcoded default.
    "anthropic": {
      "options": {
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    },
    "openai": {
      "options": {
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    },
    "openrouter": {
      "options": {
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    },
    "xai": {
      "options": {
        "baseURL": "{env:XAI_BASE_URL}",
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    },
    "google": {
      "options": {
        "baseURL": "{env:GOOGLE_BASE_URL}",
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    },
    "groq": {
      "options": {
        "baseURL": "{env:GROQ_BASE_URL}",
        "headers": { "X-Kortix-Token": "{env:KORTIX_TOKEN}" }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
