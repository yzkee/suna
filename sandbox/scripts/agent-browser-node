#!/bin/bash
# agent-browser-node — wrapper that uses Node.js daemon directly,
# bypassing the native Rust binary which crashes on Alpine musl.
#
# Usage: agent-browser-node [args...]
# Drop-in replacement for `agent-browser` CLI.
#
# The native Rust binary (agent-browser-linux-arm64) requires glibc (__res_init),
# but Alpine uses musl. The JS wrapper (agent-browser.js) also tries to spawn
# the native binary first. This wrapper goes straight to the Node.js CLI.

AB_DIR="/usr/local/lib/node_modules/agent-browser"

# If called with AGENT_BROWSER_DAEMON=1, run the daemon directly
if [ "${AGENT_BROWSER_DAEMON}" = "1" ]; then
  exec node "${AB_DIR}/dist/daemon.js" "$@"
fi

# For CLI commands, use the JS wrapper but replace the native binary with a
# symlink to /usr/bin/false so it falls through to the Node.js path.
# Actually, the JS wrapper spawns the native binary directly — we need to
# patch the PATH so it finds our shim first.

# Create a temporary shim that pretends to be the native binary but exits 1
# forcing the JS wrapper to use Node.js fallback.
# But wait — the JS wrapper doesn't have a fallback. It only tries the native binary.

# Simplest approach: run the daemon.js directly and send commands via socket.
# For that we need a CLI that talks to the daemon via socket.
# The Rust CLI is the ONLY CLI — there's no Node.js CLI equivalent.

# Alternative: install the glibc compatibility layer
# Or: build from source with musl target
# Or: use the node daemon + send raw JSON commands

# For now, check if the native binary works. If not, provide clear error.
if "${AB_DIR}/bin/agent-browser-linux-$(uname -m | sed 's/aarch64/arm64/')" --version >/dev/null 2>&1; then
  exec "${AB_DIR}/bin/agent-browser-linux-$(uname -m | sed 's/aarch64/arm64/')" "$@"
fi

# Native binary doesn't work — try installing glibc compat
if ! command -v /usr/glibc-compat/lib/ld-linux-aarch64.so.1 >/dev/null 2>&1; then
  # Try running with gcompat if available
  if command -v gcompat >/dev/null 2>&1; then
    exec "${AB_DIR}/bin/agent-browser-linux-$(uname -m | sed 's/aarch64/arm64/')" "$@"
  fi
fi

echo "Error: agent-browser native binary requires glibc (Alpine uses musl)."
echo "Install gcompat: apk add gcompat"
echo "Or start the daemon manually: AGENT_BROWSER_DAEMON=1 node ${AB_DIR}/dist/daemon.js"
exit 1
