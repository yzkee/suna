#!/usr/bin/with-contenv bash
# OpenCode API Server — DEV MODE

sleep 3
cd /workspace

mkdir -p /workspace/.local/share/opencode/log \
         /workspace/.local/share/opencode/storage \
         /workspace/.local/share/opencode/snapshot
chown -R abc:abc /workspace/.local/share/opencode

if [ ! -f /opt/opencode-src/packages/opencode/src/server/server.ts ]; then
  echo "[opencode-serve] No local source found, using global binary."
  exec s6-setuidgid abc \
    env HOME=/workspace \
        OPENCODE_CONFIG_DIR=/opt/opencode \
        OPENCODE_FILE_ROOT=/ \
        BUN_PTY_LIB=/opt/bun-pty-musl/librust_pty.so \
        PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin" \
    opencode serve --port 4096 --hostname 0.0.0.0
fi

echo "[opencode-serve] Starting from LOCAL SOURCE (/opt/opencode-src)"

# Use --cwd to resolve node_modules from the opencode monorepo, but set
# HOME and OPENCODE_FILE_ROOT to /workspace so the server operates there.
# GIT_DIR is unset to prevent git discovery from following the submodule
# .git reference that doesn't resolve inside the container.
exec s6-setuidgid abc \
  env HOME=/workspace \
      OPENCODE_CONFIG_DIR=/opt/opencode \
      OPENCODE_FILE_ROOT=/ \
      BUN_PTY_LIB=/opt/bun-pty-musl/librust_pty.so \
      GIT_DIR= \
      PATH="/opt/bun/bin:/usr/local/bin:/usr/bin:/bin" \
  /opt/bun/bin/bun run --conditions=browser --cwd /opt/opencode-src/packages/opencode /opt/opencode-dev/serve-entry.ts
