# Frontend build — exclude everything not needed
node_modules
**/node_modules

# Ignore Next.js build output by default, but keep standalone runtime artifacts
**/.next
!apps/frontend/.next/standalone
!apps/frontend/.next/standalone/**
!apps/frontend/.next/static
!apps/frontend/.next/static/**
.git
**/.env
**/.env.*
dist
**/dist
.turbo
.nx

# The big one — services/ is 6.6GB and irrelevant for frontend
services
sandbox
