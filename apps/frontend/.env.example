# Frontend environment variables
# Generated by scripts/setup-env.sh from the root .env — do not edit manually.
# See root .env.example for the source of truth.

NEXT_PUBLIC_ENV_MODE=local  # local or cloud

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
KORTIX_ADMIN_API_KEY=

NEXT_PUBLIC_FORCE_LOCALHOST=true

# Server-only: required for share page proxy (proxies to OpenCode inside sandboxes)
SUPABASE_SERVICE_ROLE_KEY=
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
