{
  "name": "kortix",
  "private": true,
  "scripts": {
    "env": "./scripts/setup-env.sh",
    "dev": "nx run-many --target=dev --projects=Kortix-Computer-Frontend,kortix-api --parallel=10",
    "dev:services": "nx run kortix-api:dev",
    "dev:frontend": "nx run Kortix-Computer-Frontend:dev",
    "dev:api": "nx run kortix-api:dev",
    "build": "nx run-many --target=build --parallel",
    "build:frontend": "nx run Kortix-Computer-Frontend:build",
    "typecheck": "nx run-many --target=typecheck --parallel",
    "stripe": "stripe listen --forward-to http://localhost:8008/webhooks/stripe",
    "docker:build": "docker compose --profile all build",
    "docker:up": "docker compose --profile all up -d",
    "docker:up:backend": "docker compose --profile backend up -d",
    "docker:up:frontend": "docker compose --profile frontend up -d",
    "docker:down": "docker compose --profile all down",
    "graph": "nx graph"
  },
  "devDependencies": {
    "nx": "^22.4.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.7"
    }
  }
}
