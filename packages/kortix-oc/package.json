{
  "name": "@kortix/kortix-oc",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "description": "Standalone Kortix OpenCode runtime package with a minimal entry config and plugin runtime",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./materialize": "./src/materialize.ts",
    "./verify": "./src/verify.ts",
    "./package.json": "./package.json"
  },
  "bin": {
    "kortix-oc": "bin/kortix-oc.ts"
  },
  "files": [
    "bin/",
    "docs/",
    "infra/",
    "runtime/agents/",
    "runtime/commands/",
    "runtime/patches/",
    "runtime/plugin/",
    "runtime/skills/",
    "runtime/tools/",
    "runtime/ocx.jsonc",
    "runtime/opencode.jsonc",
    "runtime/package.json",
    "runtime/tsconfig.json",
    "src/",
    "tests/",
    "README.md",
    "docs/migration/kortix-oc-migration-plan.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:plugin": "bun test tests/plugin/kortix-sys",
    "verify:runtime": "bun run bin/kortix-oc.ts verify",
    "materialize:tmp": "bun run bin/kortix-oc.ts materialize /tmp/kortix-opencode --clean",
    "pack:check": "npm pack --json --dry-run"
  },
  "dependencies": {
    "@kortix/opencode-agent-triggers": "0.1.0",
    "@mendable/firecrawl-js": "4.13.0",
    "@morphllm/morphsdk": "0.2.134",
    "@opencode-ai/plugin": "1.2.21",
    "@opencode-ai/sdk": "1.2.17",
    "@tavily/core": "0.7.1",
    "agent-tunnel": "npm:@kortix/agent-tunnel@0.1.0",
    "envsitter-guard": "0.0.4",
    "js-yaml": "4.1.0",
    "jsonc-parser": "3.3.1",
    "opencode-pty": "0.2.3",
    "replicate": "1.4.0",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
