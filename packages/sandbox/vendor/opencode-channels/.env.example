# opencode-channels — Environment Variables
#
# Copy to .env.test and fill in your values:
#   cp .env.example .env.test

# ── Slack credentials (optional — can be provided via /reload API instead) ──
# Get these from https://api.slack.com/apps → your app
SLACK_BOT_TOKEN=xoxb-your-bot-token        # OAuth & Permissions → Bot User OAuth Token
SLACK_SIGNING_SECRET=your-signing-secret    # Basic Information → Signing Secret

# ── Discord credentials (optional) ─────────────────────────────────────
# Get these from https://discord.com/developers/applications → your app
DISCORD_BOT_TOKEN=your-bot-token             # Bot → Token
DISCORD_PUBLIC_KEY=your-public-key           # General Information → Public Key
DISCORD_APPLICATION_ID=your-application-id   # General Information → Application ID
DISCORD_MENTION_ROLE_IDS=                    # Comma-separated role IDs (optional)

# ── Optional (defaults shown) ────────────────────────────
OPENCODE_URL=http://localhost:1707          # OpenCode server URL
PORT=3456                                    # Webhook server port
