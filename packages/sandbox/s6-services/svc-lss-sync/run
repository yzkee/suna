#!/usr/bin/with-contenv bash
# lss-sync — File-watcher daemon for semantic search indexing.
#
# OPENAI_API_KEY is optional. If not set, lss-sync is skipped entirely.
# auth-sync (kortix-master) writes the key to s6 env at boot.

# Quick check — don't block startup with a long wait loop
if [ -f /run/s6/container_environment/OPENAI_API_KEY ]; then
    OPENAI_API_KEY="$(cat /run/s6/container_environment/OPENAI_API_KEY)"
fi

if [ -z "${OPENAI_API_KEY:-}" ]; then
    echo "[lss-sync] OPENAI_API_KEY not set — polling silently in background"
    while true; do
        [ -f /run/s6/container_environment/OPENAI_API_KEY ] && \
            OPENAI_API_KEY="$(cat /run/s6/container_environment/OPENAI_API_KEY)" && \
            [ -n "$OPENAI_API_KEY" ] && break
        sleep 30
    done
    echo "[lss-sync] OPENAI_API_KEY now available — starting"
fi

if [ "$(id -u)" -eq 0 ]; then
  exec s6-setuidgid abc \
    env HOME=/workspace \
        OPENAI_API_KEY="${OPENAI_API_KEY}" \
        LSS_DIR=/workspace/.lss \
        PATH="/lsiopy/bin:/usr/local/bin:/usr/bin:/bin" \
    lss-sync \
      --watch /workspace \
      --exclude node_modules \
      --exclude .git \
      --exclude __pycache__ \
      --startup-delay 15 \
      --debounce 2
fi

exec env HOME=/workspace \
    OPENAI_API_KEY="${OPENAI_API_KEY}" \
    LSS_DIR=/workspace/.lss \
    PATH="/lsiopy/bin:/usr/local/bin:/usr/bin:/bin" \
  lss-sync \
    --watch /workspace \
    --exclude node_modules \
    --exclude .git \
    --exclude __pycache__ \
    --startup-delay 15 \
    --debounce 2
