      "run": "/etc/s6-overlay/s6-rc.d/svc-presentation-viewer/run",
      "deps": [],
      "autoStart": true,
      "restart": "always",
      "restartDelayMs": 1500
    },
    {
      "id": "static-web",
      "name": "Static Web",
      "run": "/etc/s6-overlay/s6-rc.d/svc-static-web/run",
      "deps": [],
      "autoStart": true,
      "restart": "always",
      "restartDelayMs": 1500
    }
