{
  "name": "@kortix/db",
  "version": "1.0.0",
  "description": "Kortix Database - Drizzle ORM schemas and client",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/legacy": "./src/schema/legacy/index.ts",
    "./schema/legacy/schema": "./src/schema/legacy/schema.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:pull": "bunx drizzle-kit pull --config drizzle.config.pull.ts",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "bun-types": "^1.3.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.4.0"
  }
}