{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-6",
  "default_agent": "kortix",

  "plugin": [
    "opencode-pty/plugin",
    "./plugin/worktree.ts",
    "./plugin/kortix-memory/src/index.ts",
    "./plugin/kortix-continuation/index.ts",
    "./plugin/agent-tunnel/index.ts",
    "./plugin/morph.ts",
    "./plugin/orphan-tool-fixer.ts",
    "./plugin/agent-triggers.ts"
  ],

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
