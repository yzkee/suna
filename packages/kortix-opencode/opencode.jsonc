{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "autoupdate": false,
  "model": "kortix/claude-sonnet",
  "default_agent": "kortix",
  "provider": {
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}"
      },
      "models": {
        "claude-sonnet": {
          "name": "Claude Sonnet 4.6",
          "id": "anthropic/claude-sonnet-4.6",
          "family": "kortix",
          "cost": { "input": 3, "output": 15 },
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-opus": {
          "name": "Claude Opus 4.6",
          "id": "anthropic/claude-opus-4.6",
          "family": "kortix",
          "cost": { "input": 5, "output": 25 },
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-haiku": {
          "name": "Claude Haiku 4.5",
          "id": "anthropic/claude-haiku-4.5",
          "family": "kortix",
          "cost": { "input": 0.80, "output": 4 },
          "limit": { "context": 200000, "output": 8192 }
        },
        "gpt-codex": {
          "name": "GPT-5.3 Codex",
          "id": "openai/gpt-5.3-codex",
          "family": "kortix",
          "cost": { "input": 1.75, "output": 14 },
          "limit": { "context": 400000, "output": 8192 }
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "kortix",
          "cost": { "input": 0.45, "output": 2.20 },
          "limit": { "context": 262144, "output": 8192 }
        },
        "grok-fast": {
          "name": "Grok 4.1 Fast",
          "id": "x-ai/grok-4.1-fast",
          "family": "kortix",
          "cost": { "input": 0.20, "output": 0.50 },
          "limit": { "context": 200000, "output": 8192 }
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "kortix",
          "cost": { "input": 0.295, "output": 1.20 },
          "limit": { "context": 196608, "output": 8192 }
        },
        "glm": {
          "name": "GLM-5",
          "id": "z-ai/glm-5",
          "family": "kortix",
          "cost": { "input": 0.95, "output": 2.55 },
          "limit": { "context": 204800, "output": 8192 }
        }
      }
    }
  },
  "plugin": [
    "file:///opt/opencode/node_modules/opencode-pty/src/plugin.ts",
    "./plugin/worktree.ts",
    "./plugin/kortix-memory/src/index.ts",
    "./plugin/kortix-continuation/index.ts",
    "./plugin/morph.ts",
    "./plugin/orphan-tool-fixer.ts",
    "./plugin/agent-triggers.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
