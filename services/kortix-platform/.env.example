PORT=8012
ENV_MODE=local

# Database (Drizzle ORM)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase (JWT auth verification only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Kortix Router URL (injected into sandboxes as KORTIX_URL env var)
KORTIX_URL=http://localhost:8008

# ── Sandbox Provisioning ─────────────────────────────────────────────────────
# Provider: 'daytona' (cloud only), 'local_docker' (local only), or 'auto' (both)
SANDBOX_PROVIDER=auto

# Daytona (cloud sandbox provider)
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=kortix-sandbox-v0.4.1

# Local Docker (self-hosted sandbox provider)
SANDBOX_IMAGE=heyagi/sandbox:latest
# DOCKER_HOST=unix:///var/run/docker.sock  # default
# SANDBOX_NETWORK=                         # custom Docker network (optional)
