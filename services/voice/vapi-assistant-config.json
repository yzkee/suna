{
  "_readme": [
    "Recommended VAPI assistant configuration for the OpenCode voice proxy.",
    "Apply these settings to assistant c1213132-7b17-461b-a4e5-6e3da1039165",
    "via the VAPI dashboard (https://dashboard.vapi.ai) or the VAPI API.",
    "",
    "Key changes from defaults:",
    "  - Smart endpointing (LiveKit) for fast, accurate turn detection",
    "  - VAD-based interruption (50-100ms) instead of word-count based",
    "  - Idle message hooks for silence during long agent operations",
    "  - Flush syntax enabled (chunkPlan) for immediate acknowledgments"
  ],

  "model": {
    "provider": "custom-llm-openai",
    "url": "https://e24cb8659ac9.ngrok.app/chat/completions",
    "model": "opencode"
  },

  "voice": {
    "provider": "11labs",
    "voiceId": "21m00Tcm4TlvDq8ikWAM",
    "chunkPlan": {
      "enabled": true
    }
  },

  "startSpeakingPlan": {
    "smartEndpointingPlan": {
      "provider": "livekit",
      "waitFunction": "2000 / (1 + exp(-10 * (x - 0.5)))"
    },
    "waitSeconds": 0.4
  },

  "stopSpeakingPlan": {
    "numWords": 0,
    "voiceSeconds": 0.2,
    "backoffSeconds": 1.0
  },

  "hooks": [
    {
      "on": "customer.speech.timeout",
      "name": "idle_working",
      "options": {
        "timeoutSeconds": 12,
        "triggerMaxCount": 3,
        "triggerResetMode": "onUserSpeech"
      },
      "do": [
        {
          "type": "say",
          "exact": [
            "Still working on that, one moment.",
            "Bear with me, the agent is still running.",
            "Almost there, just waiting on results."
          ]
        }
      ]
    },
    {
      "on": "customer.speech.timeout",
      "name": "idle_checkin",
      "options": {
        "timeoutSeconds": 25,
        "triggerMaxCount": 2,
        "triggerResetMode": "onUserSpeech"
      },
      "do": [
        {
          "type": "say",
          "exact": [
            "Are you still there? Let me know if you need anything.",
            "I'm here whenever you're ready."
          ]
        }
      ]
    },
    {
      "on": "customer.speech.timeout",
      "name": "idle_end",
      "options": {
        "timeoutSeconds": 60,
        "triggerMaxCount": 1,
        "triggerResetMode": "never"
      },
      "do": [
        {
          "type": "say",
          "exact": "It seems like you've stepped away. I'll end the call now, feel free to call back anytime."
        },
        {
          "type": "tool",
          "tool": { "type": "endCall" }
        }
      ]
    }
  ]
}
