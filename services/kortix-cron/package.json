{
  "name": "kortix-cron",
  "version": "1.0.0",
  "description": "Kortix Cron - Scheduled agent trigger service",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__/",
    "test:unit": "bun test src/__tests__/cron.test.ts",
    "test:integration": "bun test src/__tests__/sandboxes.test.ts src/__tests__/triggers.test.ts src/__tests__/executions.test.ts",
    "test:e2e": "bun test src/__tests__/e2e-lifecycle.test.ts src/__tests__/scheduler.test.ts"
  },
  "dependencies": {
    "@kortix/db": "workspace:*",
    "@supabase/supabase-js": "^2.39.0",
    "croner": "^9.0.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.4.0"
  }
}
